# Client data never leaves the machine via git
clients/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Local env / secrets
.env
*.key

# Scan results (per-run, like client data — never commit)
readiness/.scans/

# Outreach drafts (generated, contain scan data)
outreach/

# Leaderboard output (generated data, not post-assets)
leaderboard/*
!leaderboard/post-assets/
!leaderboard/diff_report.py
!leaderboard/generate_post_assets.py
!leaderboard/spotcheck.py
